{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/gh/:path*", "destination": "https://api.github.com/:path*" },
    { "source": "/api/searx1/:path*", "destination": "https://searx.be/:path*" },
    { "source": "/api/searx2/:path*", "destination": "https://search.sapti.me/:path*" },
    { "source": "/api/searx3/:path*", "destination": "https://search.ononoki.org/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
